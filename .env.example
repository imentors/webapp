# Database URL from Neon
NUXT_NEON_DATABASE_URL=postgresql://[user]:[password]@[neon-host]/[dbname]?sslmode=require

# Better Auth Configuration
NUXT_BETTER_AUTH_SECRET=your-secret-key-min-32-chars-long
NUXT_BETTER_AUTH_URL=http://localhost:3000

# Google OAuth
NUXT_GOOGLE_CLIENT_ID=your-google-client-id
NUXT_GOOGLE_CLIENT_SECRET=your-google-client-secret

# LinkedIn OAuth
NUXT_LINKEDIN_CLIENT_ID=your-linkedin-client-id
NUXT_LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# Email (Brevo)
NUXT_BREVO_API_KEY=your-brevo-api-key

# OpenAI
NUXT_OPENAI_API_KEY=your-openai-api-key

# JaaS (Jitsi as a Service) - Video Meetings
# Get your credentials from https://jaas.8x8.vc/
NUXT_JAAS_APP_ID=vpaas-magic-cookie-xxxxxxxxxxxxxxxxxxxxxxxx
NUXT_JAAS_KEY_ID=your-api-key-id
NUXT_JAAS_API_KEY="-----BEGIN RSA PRIVATE KEY-----
your-private-key-here
-----END RSA PRIVATE KEY-----"

# AWS S3 Storage
NUXT_AWS_REGION=us-east-1
NUXT_AWS_ACCESS_KEY_ID=your-access-key
NUXT_AWS_SECRET_ACCESS_KEY=your-secret-key
NUXT_AWS_S3_BUCKET=imentor-uploads
# AWS_ENDPOINT_URL=http://localhost:9000 # Optional for MinIO/LocalStack
